{
    "type": "Categorization",
    "elements": [
        {
            "type": "Category",
            "label": "Basic Intro",
            "elements": [
                {"type": "Label",
                "text": "Before we begin please let us know if you are reporting an incident agaisnt yourself, or on behalf of another person"},
                {
                    "type": "VerticalLayout",
                    "elements": [
                        {
                            "type": "Control",
                            "scope": "#/properties/WitnessOrVictim",
                            "label": "Please indicate if you are reporting on behalf of someone",
                            "options": {
                                "format": "radio"
                            }
                        },
                        {
                            "type": "Control",
                            "label": "Does the victim know you are filing this report?",
                            "scope": "#/properties/victimAwareness",
                            "options": {
                                "format": "radio"
                            },
                            "rule": {
                            "effect": "SHOW",
                            "condition": {
                            "scope": "#/properties/WitnessOrVictim",
                            "schema": {
                                "const": "Witness"
                                }

                            }
                        }
                        }                        
                    ]
                }
            ]},
        {
            "type": "Category",
            "label": "Time, Date & Location",
            "elements": [
                {
                    "type": "VerticalLayout",
                    "elements": [
                        {"type": "Label",
                            "text": "Thank you for taking the time to to report what you have witnessed. This section will focus on the 'where' and 'when' of the incident."},
                            
                        {
                            "type": "HorizontalLayout",
                            "elements": [
                                {"type": "Control",
                            "label": "Can you recall the Date of the incident?",
                            "scope": "#/properties/WitnessFlow/properties/WitnessWhen/properties/DateRecall",
                            "options": {
                                "format": "radio"
                            }
                        },
                        {"type": "Control",
                        "label": "Please indicate the date",
                        "scope": "#/properties/WitnessFlow/properties/WitnessWhen/properties/IncidentDate",
                        "rule": {
                            "effect": "SHOW",
                            "condition": {
                                "scope": "#/properties/WitnessFlow/properties/WitnessWhen/properties/DateRecall",
                                "schema": {
                                    "const": "Yes"
                                    }
    
                                }
                        }}
                        ]},
                        {"type":"Control",
                        "label": "Where did this incident take place? Any and all information could be imprtant, please give as much detail as possible",
                        "scope": "#/properties/WitnessFlow/properties/WitnessWhere/properties/Where" },
                        {
                            "type":"Control",
                            "label": "Please tell us who the perpetrator was. \n This information is completely anonymous. If you name the perpetrator, they will not be able to trace the report back to you. Furthermore, no one in your organisation will be able to identify you.",
                            "scope": "#/properties/WitnessFlow/properties/WitnessWhere/properties/Perpetrator"
                            },
                        {"type": "Label",
                        "text": "Space"},
                        {"type":"Control",
                        "label": "What is the relationship between yorself and the perpetrator",
                        "scope": "#/properties/WitnessFlow/properties/WitnessWhere/properties/PerpetratorRelation"}
                    ]
                }

            ],
            "rule":{
                "effect":"SHOW",
                "condition":{
                    "scope": "#/properties/WitnessFlow/properties/WitnessWhen/properties/DateRecall",
                    "schema": {
                        "enum": [
                            "Yes",
                            "No"
                        ]
                        }

                    }
            }
        },
        {
            "type": "Category",
            "label": "Parties involved",
            "rule":{
                "effect":"SHOW",
                "condition":{
                    "scope": "#/properties/WitnessOrVictim",
                    "schema": {
                        "enum": [
                            "Victim",
                            "Witness"
                        ]
                        }

                    }
            }}
        
                ],
        "options": {
            "variant": "stepper",
            "showNavButtons": true
            }
}