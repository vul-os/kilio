{
    
    "type": "object",
    "properties": {
        "WitnessOrVictim": {
            "type": "string",
            "enum": [
                "Victim",
                "Witness"
            ]
        },
        "victimAwareness": {
            "type": "string",
            "enum": [
                "Yes",
                "No"
            ]
        },
        "WitnessFlow": {
            "type": "object",
            "properties": {
                "WitnessWhen": {
                    "type": "object",
                    "properties": {
                        "DateRecall": {
                            "type": "string",
                            "enum": [
                                "Yes",
                                "No",
                                "Skip"
                            ]
                        },
                        "IncidentDate":{
                            "type": "string",
                            "format": "date"
                        }
                    },
                    "required":[
                        "DateRecall"
                    ]
                },
                "WitnessWhere": {
                    "type": "object",
                    "properties": {
                        "Where": {
                            "type": "string"
                        }}},
                        "WitnessWho": {
                            "type":"object",
                            "properties": {
                        "Perpetrator": {
                            "type": "string"
                        },
                        "PerpetratorRelationWitness": {
                            "type": "string",
                            "enum": ["Colleague",
                                    "Manager",
                                    "Supervisor",
                                    "Department Head",
                                    "HR",
                                    "Other"]
                        },
                        "PerpetratorRelationVictim": {
                            "type": "string",
                            "enum": ["Colleague",
                                    "Manager",
                                    "Supervisor",
                                    "Department Head",
                                    "HR",
                                    "I dont know",
                                    "Other"]
                        },
                        "AdditionalWitnesses": {
                            "type":"string",
                            "enum": [
                                "Yes",
                                "No"
                            ]
                        },
                        "AdditionalWitnessesNumber": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 99
                        },
                        "WitnessReported": {
                            "type": "string",
                            "enum": [
                                "Yes",
                                "No"
                            ]
                        },
                        "WitnessReportedWhere": {
                            "type":"string"
                        }}},
                        "WitnessNatureIncident": {
                            "type":"object",
                            "properties":{
                                "IncidentDetails": {
                                    "type":"string"
                                },
                                "TypeOfDiscrimination": {
                                    "type":"object",
                                    "properties": {
                                        "Race": {
                                            "type": "boolean"
                                        },
                                        "Age": {
                                            "type": "boolean"
                                        },
                                        "Gender": {
                                            "type": "boolean"
                                        },
                                        "SexualOrientation": {
                                            "type": "boolean"
                                        },
                                        "ReligiousAffiliation": {
                                            "type": "boolean"
                                        },
                                        "PoliticalAffiliation": {
                                            "type": "boolean"
                                        },
                                        "MartialStatus": {
                                            "type": "boolean"
                                        },
                                        "SocioEconomicClass": {
                                            "type": "boolean"
                                        },
                                        "Pregnancy": {
                                            "type": "boolean"
                                        },
                                        "Disability": {
                                            "type": "boolean"
                                        },
                                        "Language": {
                                            "type": "boolean"
                                        },
                                        "Other": {
                                            "type": "boolean"
                                        }
                                    }
                                }  
            }
        }

            }
        }
    },
    "required": [
        "WitnessOrVictim"
    ]
}