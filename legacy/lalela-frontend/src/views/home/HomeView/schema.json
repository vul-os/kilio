{
    
    "type": "object",
    "properties": {
        "WitnessOrVictim": {
            "type": "string",
            "enum": [
                "Victim",
                "Witness"
            ]
        },
        "victimAwareness": {
            "type": "string",
            "enum": [
                "Yes",
                "No"
            ]
        },
        "WitnessFlow": {
            "type": "object",
            "properties": {
                "WitnessWhen": {
                    "type": "object",
                    "properties": {
                        "DateRecall": {
                            "type": "string",
                            "enum": [
                                "Yes",
                                "No",
                                "Skip"
                            ]
                        },
                        "IncidentDate":{
                            "type": "string",
                            "format": "date"
                        }
                    },
                    "required":[
                        "DateRecall"
                    ]
                },
                "WitnessWhere": {
                    "type": "object",
                    "properties": {
                        "Where": {
                            "type": "string"
                        }}},
                        "WitnessWho": {
                            "type":"object",
                            "properties": {
                        "Perpetrator": {
                            "type": "string"
                        },
                        "PerpetratorRelationWitness": {
                            "type": "string",
                            "enum": ["Colleague",
                                    "Manager",
                                    "Supervisor",
                                    "Department Head",
                                    "HR",
                                    "Other"]
                        },
                        "PerpetratorRelationVictim": {
                            "type": "string",
                            "enum": ["Colleague",
                                    "Manager",
                                    "Supervisor",
                                    "Department Head",
                                    "HR",
                                    "I dont know",
                                    "Other"]
                        },
                        "AdditionalWitnesses": {
                            "type":"string",
                            "enum": [
                                "Yes",
                                "No"
                            ]
                        },
                        "AdditionalWitnessesNumber": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 99
                        },
                        "WitnessReported": {
                            "type": "string",
                            "enum": [
                                "Yes",
                                "No"
                            ]
                        },
                        "WitnessReportedWhere": {
                            "type":"string"
                        }}},
                        "WitnessNatureIncident": {
                            "type":"object",
                            "properties":{
                                "IncidentDetails": {
                                    "type":"string"
                                },
                                "TypeOfDiscrimination": {
                                    "type":"object",
                                    "properties": {
                                        "Race": {
                                            "type": "boolean"
                                        },
                                        "Age": {
                                            "type": "boolean"
                                        },
                                        "Gender": {
                                            "type": "boolean"
                                        },
                                        "SexualOrientation": {
                                            "type": "boolean"
                                        },
                                        "ReligiousAffiliation": {
                                            "type": "boolean"
                                        },
                                        "PoliticalAffiliation": {
                                            "type": "boolean"
                                        },
                                        "MartialStatus": {
                                            "type": "boolean"
                                        },
                                        "SocioEconomicClass": {
                                            "type": "boolean"
                                        },
                                        "Pregnancy": {
                                            "type": "boolean"
                                        },
                                        "Disability": {
                                            "type": "boolean"
                                        },
                                        "Language": {
                                            "type": "boolean"
                                        },
                                        "Other": {
                                            "type": "boolean"
                                        }
                                    }
                                },
                                "TypeOfWorkplaceViolence": {
                                    "type":"object",
                                    "properties": {
                                        "WorkplaceBullying": {
                                            "type": "boolean"
                                        },
                                        "VerbalHarassment": {
                                            "type": "boolean"
                                        },
                                        "PhysicalHarassment": {
                                            "type": "boolean"
                                        },
                                        "SexualHarassment": {
                                            "type": "boolean"
                                        },
                                        "RacialDiscrimination": {
                                            "type": "boolean"
                                        },
                                        "Homophobia": {
                                            "type": "boolean"
                                        },
                                        "Transphobia": {
                                            "type": "boolean"
                                        },
                                        "Ableism": {
                                            "type": "boolean"
                                        },
                                        "Other": {
                                            "type": "boolean"
                                        }
                                    }},
                                    "WitnessTypeBefore": {
                                        "type":"string",
                                        "enum": [
                                            "Yes",
                                            "No"
                                        ]
                                    },
                                    "WitnessSamePerpBefore": {
                                        "type":"string",
                                        "enum": [
                                            "Yes",
                                            "No"
                                        ]
                                    },
                                    "WitnessRepeatIncident": {
                                        "type":"string",
                                        "enum": [
                                            "Yes",
                                            "No"
                                        ]
                                    },
                                    "WitnessReportTo": {
                                        "type":"string",
                                        "enum": [
                                            "Yes",
                                            "No"
                                        ]
                                    }

            }
        },
        "WitnessEmotionalEvaluation": {
            "type":"object",
            "properties": {
                "WitnessFeeling": {
                    "type": "string"
                },
                "WitnessFeelingTime": {
                    "type": "string"
                },
                "WitnessFeelingCurrent": {
                    "type": "string",
                    "enum": [
                        "Yes",
                        "No"
                    ]
                },
                "WitnessSafety": {
                    "type":"string",
                    "enum": [
                        "yes",
                        "No"
                    ]
                },
                "WitnessJobSafety": {
                    "type": "string",
                    "enum": [
                        "Yes",
                        "No"
                    ]
                },
                "WitnessJobActions": {
                    "type": "object",
                    "properties": {
                       "ChangeInDepartment": {
                           "type":"boolean"
                       },
                       "ChangeInTeams": {
                           "type":"boolean"
                       },
                       "Resignation": {
                           "type": "boolean"
                       },
                       "Other": {
                           "type":"boolean"
                       },
                       "WitnessJobActionsOther": {
                           "type":"string"
                       } 
                    }
                },
                "WitnessEmotionAction": {
                    "type":"string",
                    "enum": [
                        "Yes",
                        "No"
                    ]
                },
                "WitnessEmotionActionExplained": {
                    "type": "string"
                },
                "WitnessEventHandling": {
                    "type":"object",
                    "properties": {
                        "WitnessSanctionedIncident": {
                            "type":"string",
                            "enum": ["Yes",
                                    "No"]
                        },
                        "WitnessSanctionedIncidentApology": {
                            "type":"boolean"
                        },
                        "WitnessSanctionedIncidentVerbalWarning": {
                            "type":"boolean"
                        },
                        "WitnessSanctionedIncidentWrittenWarning": {
                            "type":"boolean"
                        },
                        "WitnessSanctionedIncidentSuspension": {
                            "type":"boolean"
                        },
                        "WitnessSanctionedIncidentDismissal": {
                            "type":"boolean"
                        },
                        "WitnessSanctionedIncidentOther": {
                            "type":"boolean"
                        },
                        "WitnessSanctionedIncidentOtherExplained": {
                            "type":"string"
                        },
                        "WitnessIncidentSensitivityTraining": {
                            "type":"string",
                            "enum": [
                                "Yes",
                                "No"
                            ]
                        }

                    }
                }
            }
        },
        "WitnessSupportingDocuments": {
            "type":"object",
            "properties": {
                "uploadDoc": {
                    "type":"object"
                }
            }
        }

            }
        }
    },
    "required": [
        "WitnessOrVictim"
    ]
}